# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
.gstack/

# typescript incremental build cache
tsconfig.tsbuildinfo

# generated by xcodegen from tvos/project.yml
tvos/*.xcodeproj

# generated from app/bodies.ts + public/textures by `npm run catalog`
tvos/HeliosTV/Resources/
tvos/HeliosTVTests/Resources/

# rendered narration audio (real money — see scripts/render-narration.mjs)
.narration-cache/
.narration-samples/
