{
  "name": "solar-system-atlas",
  "version": "0.1.0",
  "private": true,
  "displayName": "Solar System Atlas",
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "scripts": {
    "build": "npm run catalog && next build",
    "catalog": "node --experimental-strip-types scripts/emit-catalog.mjs && node --experimental-strip-types scripts/emit-orbit-goldens.mjs",
    "dev": "next dev",
    "galaxy-maps": "node --experimental-strip-types scripts/bake-galaxy-maps.mjs && node --experimental-strip-types scripts/bake-local-group.mjs",
    "local-group-maps": "node --experimental-strip-types scripts/bake-local-group.mjs",
    "universe-field": "node --experimental-strip-types scripts/bake-universe-field.mjs",
    "universe-cmb": "node scripts/bake-universe-cmb.mjs",
    "lint": "eslint .",
    "narration": "node --experimental-strip-types scripts/render-narration.mjs",
    "preview": "npx --yes serve out",
    "test": "npm run build && node --test --experimental-strip-types \"tests/*.test.mjs\""
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.180.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  }
}
